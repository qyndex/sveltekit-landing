# SvelteKit Landing — environment variables
# Copy to .env and fill in values before running locally.

# Public variables are exposed to the browser (VITE_ prefix or PUBLIC_ prefix via $env/static/public)

# Site metadata (optional overrides — defaults are set in +page.server.ts)
# PUBLIC_SITE_NAME=Launchpad
# PUBLIC_SITE_DESCRIPTION=The modern platform for building and shipping web applications.

# Analytics (optional)
# PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# Contact / CRM webhook (optional — used by a future /contact form action)
# CONTACT_WEBHOOK_URL=https://hooks.example.com/contact

# Node environment
NODE_ENV=development
