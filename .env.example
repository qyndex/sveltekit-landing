# SvelteKit Landing — environment variables
# Copy to .env and fill in values before running locally.

# ── Supabase (required) ─────────────────────────────────────────────────────
# Public vars are exposed to the browser via $env/dynamic/public
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — used server-side only (never sent to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site metadata (optional overrides) ───────────────────────────────────────
# PUBLIC_SITE_NAME=Launchpad
# PUBLIC_SITE_DESCRIPTION=The modern platform for building and shipping web applications.

# ── Analytics (optional) ─────────────────────────────────────────────────────
# PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# Node environment
NODE_ENV=development
